# ScribeAI Enhanced Configuration

# Database Configuration
# Options: 'sqlite' (local) or 'postgresql' (production)
DB_TYPE=sqlite

# SQLite (Local Development)
DATABASE_URL=sqlite:///data/clinical_records.db

# Audio Recording Configuration
SAMPLE_RATE=44100
AUDIO_CHANNELS=1

# Speech Recognition (Whisper)
WHISPER_MODEL=base

# Language Model (Ollama + BioMistral)
OLLAMA_MODEL=cniongolo/biomistral
OLLAMA_BASE_URL=http://localhost:11434

# Multilingual Support
DEFAULT_LANGUAGE=en

# Audio Processing
NOISE_ESTIMATION_METHOD=spectral
DEFAULT_FILTER_TYPE=bandpass

# Max recording file size (MB)
MAX_RECORDING_SIZE=500

# Data Privacy & Compliance
DATA_PRIVACY_LEVEL=HIPAA

# ABDM Configuration
ABDM_ENABLED=true
ABDM_CHECK_COMPLIANCE=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=scribeai.log

# ── WhatsApp / Twilio Integration ─────────────────────────────────────────────
# Fill in your Twilio credentials below.
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_WHATSAPP=whatsapp:+14155238886
TWILIO_CONTENT_SID=your_content_sid_here

# ── API Security ───────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_secret_key_here
